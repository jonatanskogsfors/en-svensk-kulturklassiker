---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Fem kulturupplevelser. Ett år. En klassiker.' } = Astro.props;
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="sv">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} – En svensk kulturklassiker</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&family=Inter:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/png" href={`${base}sigill.png`} />
  </head>
  <body>
    <header class="site-header">
      <nav class="nav container">
        <a href={base} class="nav__logo" aria-label="En svensk kulturklassiker – startsidan">
          <img src={`${base}sigill.png`} alt="En svensk kulturklassiker – sigill" width="40" height="40" />
          <span>En svensk kulturklassiker</span>
        </a>
        <ul class="nav__links">
          <li class="nav__item--dropdown">
            <a href={base} aria-current={currentPath === '/' ? 'page' : undefined} aria-haspopup="true">
              Start
              <svg width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <ul class="nav__dropdown">
              <li><a href={`${base}#om-klassikern`}>Om klassikern</a></li>
              <li><a href={`${base}#kategorier`}>Kategorierna</a></li>
              <li><a href={`${base}#hur-det-fungerar`}>Hur det fungerar</a></li>
              <li><a href={`${base}#diplom`}>Diplomet</a></li>
            </ul>
          </li>
          <li><a href={`${base}anmalan`} aria-current={currentPath.includes('anmalan') ? 'page' : undefined}>Anmäl dig</a></li>
          <li><a href={`${base}om`} aria-current={currentPath.includes('/om') ? 'page' : undefined}>Om projektet</a></li>
        </ul>
      </nav>
    </header>

    <div class="demo-ribbon" aria-label="Demo-banner">
      <span>Kul att du hittat hit!<br>Detta är en offentlig DEMO.</span>
    </div>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="footer__logo">En svensk kulturklassiker</div>
        <ul class="footer__nav">
          <li><a href={base}>Start</a></li>
          <li><a href={`${base}anmalan`}>Anmäl dig</a></li>
          <li><a href={`${base}om`}>Om projektet</a></li>
        </ul>
        <p class="footer__copy">&copy; {new Date().getFullYear()} En svensk kulturklassiker. Alla rättigheter förbehållna.</p>
      </div>
    </footer>
  <script>
    const navItem = document.querySelector('.nav__item--dropdown');
    const trigger = navItem?.querySelector('a');

    // Öppna/stäng med klass vid klick på "Start"
    trigger?.addEventListener('click', (e) => {
      if (window.innerWidth < 640) {
        e.preventDefault();
        navItem?.classList.toggle('is-open');
      }
    });

    // Stäng när ett val görs i dropdown
    navItem?.querySelectorAll('.nav__dropdown a').forEach(link => {
      link.addEventListener('click', () => {
        navItem.classList.remove('is-open');
      });
    });

    // Stäng vid klick utanför
    document.addEventListener('click', (e) => {
      if (!navItem?.contains(e.target as Node)) {
        navItem?.classList.remove('is-open');
      }
    });
  </script>
  </body>
</html>
